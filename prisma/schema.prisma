// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Subscription tier enum
enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum TeamRole {
  ADMIN
  VIEWER
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

// User model synced from Clerk
model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique // Clerk user ID (user_xxx)
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?

  // Subscription relationship
  subscription Subscription?

  // Workspace and team relationships
  personalWorkspace Workspace?
  teamMemberships   TeamMember[]
  createdTeams      Team[]       @relation("TeamCreator")
  createdConnections Connection[] @relation("ConnectionCreator")

  // Usage tracking
  usageRecords UsageRecord[]
  bookmarks    Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Subscription model
model Subscription {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier SubscriptionTier @default(FREE)

  // For future Stripe integration
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // Subscription period
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// Usage tracking for tier limits
model UsageRecord {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Usage metrics
  month          DateTime // First day of the month (for grouping)
  uploadBytes    BigInt   @default(0) // Total bytes uploaded this month
  downloadBytes  BigInt   @default(0) // Total bytes downloaded this month
  operationCount Int      @default(0) // API operations count

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@map("usage_records")
}

model Team {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  createdById String
  createdBy   User         @relation("TeamCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     TeamMember[]
  workspace   Workspace?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

model TeamMember {
  id     String   @id @default(uuid())
  teamId String
  userId String
  role   TeamRole @default(VIEWER)
  team   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Workspace {
  id     String        @id @default(uuid())
  type   WorkspaceType
  userId String?       @unique
  teamId String?       @unique
  user   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  connections Connection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("workspaces")
}

// S3 Connection configuration
// Stores connection details for S3-compatible storage endpoints
model Connection {
  id              String  @id @default(uuid())
  name            String? // Optional display name for the connection
  endpoint        String // S3 endpoint URL (e.g., https://s3.amazonaws.com)
  region          String  @default("us-east-1")
  accessKeyId     String // AWS access key ID
  secretAccessKey String // AES-256-GCM encrypted; use src/lib/crypto.ts to decrypt
  forcePathStyle  Boolean @default(true) // Required for MinIO and some S3-compatible services

  // Workspace ownership
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?     @relation("ConnectionCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookmarks Bookmark[]

  @@index([workspaceId])

  @@map("connections")
}

model Bookmark {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  bucket       String
  prefix       String?
  label        String?
  createdAt    DateTime   @default(now())

  @@unique([userId, connectionId, bucket, prefix])
  @@index([userId, connectionId])
  @@index([userId, connectionId, bucket])
  @@map("bookmarks")
}
