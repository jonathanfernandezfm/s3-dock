# Database Configuration
# ======================
# Replace with your PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Examples:
# - Local: postgresql://postgres:postgres@localhost:5432/s3client?schema=public
# - Docker: postgresql://postgres:postgres@db:5432/s3client?schema=public
# - Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# - Neon: postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]?sslmode=require

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Note: For production, ensure you're using SSL connections and secure passwords

# Clerk Authentication
# ====================
# Get these from https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY

# Clerk Webhook Secret (for syncing users to database)
# Get this from Clerk Dashboard > Webhooks after creating a webhook endpoint
CLERK_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# Clerk URLs (optional - these are the defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app/buckets
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app/buckets

# Secret Encryption
# =================
# 32-byte key as 64 hex characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# Share Link Cookie Secret
# ========================
# 64-char hex (32 bytes). Generate with: openssl rand -hex 32
SHARE_LINK_COOKIE_SECRET=

# Global Search Index
# ===================
# Master kill switch — set to "true" to enable search indexing and the /api/search endpoint.
# When false (default), all search code is dormant and no S3 crawling occurs.
SEARCH_INDEX_ENABLED=false

# Required when SEARCH_INDEX_ENABLED=true.
# Authenticates internal cron routes (/api/internal/crawl, /api/internal/reconcile).
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=

# Stripe Billing
# ==============
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a recurring price in Stripe Dashboard and paste the price ID here
# Product: "S3 Dock PRO", Price: $4/month (recurring)
STRIPE_PRO_PRICE_ID=price_...

# PostHog Analytics
# =================
# Get these from your PostHog project settings: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
